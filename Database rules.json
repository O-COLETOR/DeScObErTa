{
  "rules": {
    "usernames": {
      "$nomeKey": {
        ".read": true,
        ".write": "!data.exists() && auth != null && newData.val() === auth.uid"
      }
    },
    "users": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid && !data.exists()"
      }
    },
    "userMeta": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "lastCommentTs": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "comments": {
      "$postId": {
        ".read": true,
        "$commentId": {
          ".write": "(auth != null && newData.child('nome').val() === root.child('users/' + auth.uid + '/nome').val() && (!root.child('userMeta/' + auth.uid + '/lastCommentTs').exists() || newData.child('ts').val() - root.child('userMeta/' + auth.uid + '/lastCommentTs').val() > 15000)) || (auth != null && auth.uid === 'iVUD07u9vyNaFqQgGf34P3JCh8u2')"
        }
      }
    },
    "reports": {
      ".read": "auth != null && auth.uid === 'iVUD07u9vyNaFqQgGf34P3JCh8u2'",
      "$reportId": {
        ".write": "auth != null && (auth.uid === 'iVUD07u9vyNaFqQgGf34P3JCh8u2' || newData.exists())"
      }
    }
  }
}
